                    ],
                    "title": "Remote-First",
                    "description": "A computer, internet, and discipline. That's the barrier to entry. We train from anywhere because the military taught us how to operate anywhere.",
                    "path": "/about-us",
                    "pathText": "Start here"
                },
                {
                    "id": 2,
                    "images": [
                        {
                            "src": "https://res.cloudinary.com/vetswhocode/image/upload/v1746105263/5_beplkr.png"
                        }
                    ],
                    "title": "Market-Driven Curriculum",
                    "description": "128 Lightcast-validated skills across 25 modules. Every skill maps to actual job postings. If employers aren't hiring for it, we don't teach it.",
                    "path": "/about-us",
                    "pathText": "Start here"
                },
                {
                    "id": 3,
                    "images": [
                        {
                            "src": "https://res.cloudinary.com/vetswhocode/image/upload/v1746105262/1_tvrmfb.png"
                        }
                    ],
                    "title": "Mentorship, Not Hand-Holding",
                    "description": "Your mentors operate as engineering managers, not tutors. You'll learn to think, debug, and ship under the same pressure you'll face on the job.",
                    "path": "/about-us",
                    "pathText": "Start here"
                }
            ],
            "motto": {
                "text": "Empowering Veterans through Software Engineering.",
