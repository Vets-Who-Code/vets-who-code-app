            }
        },
        {
            "section": "funfact-area",
            "section_title": {
                "title": "Who We <span> Are</span>",
                "subtitle": "Rooted in Experience,<strong>Focused on Outcomes</strong>",
                "description": "We were founded by veterans who went through the same broken transition pipeline and decided to build something that actually works. Our filter is simple: if it doesn't lead to a job, we don't teach it. Every module in our curriculum maps to skills that employers are actively hiring for — validated by Lightcast labor market data, not guesswork. We keep cohorts small, mentorship direct, and outcomes measurable. Ten years, 300+ graduates, $20M+ in collective earnings. That's the mission statement."
            },
            "motto": {
                "text": "Want To Learn More?​",
                "path": "/about-us",
                "pathText": "Start here"
            },
